{
    "name": "cmyk-preview-toolkit",
    "version": "2.0.0",
    "description": "Dual CMYK/sRGB color handling for browser-based PDF editors. Convert between CMYK, RGB, HSL, and CIE Lab color spaces with press-accurate preview and palette snapping.",
    "license": "MIT",
    "author": "Manojkumar Vishwakarma <manojvistv@gmail.com>",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./palette": {
            "types": "./dist/palette.d.ts",
            "import": "./dist/palette.js",
            "require": "./dist/palette.cjs"
        },
        "./state": {
            "types": "./dist/state.d.ts",
            "import": "./dist/state.js",
            "require": "./dist/state.cjs"
        },
        "./react": {
            "types": "./dist/usePaletteColor.d.ts",
            "import": "./dist/usePaletteColor.js",
            "require": "./dist/usePaletteColor.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "lint": "eslint 'src/**/*.ts' 'react/**/*.ts' 'tests/**/*.ts'",
        "format": "prettier --write 'src/**/*.ts' 'react/**/*.ts' 'tests/**/*.ts'",
        "format:check": "prettier --check 'src/**/*.ts' 'react/**/*.ts' 'tests/**/*.ts'",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/react": "^19.2.14",
        "eslint": "^10.0.2",
        "prettier": "^3.8.1",
        "tsup": "^8.0.0",
        "typescript": "^5.4.0",
        "typescript-eslint": "^8.56.1",
        "vitest": "^2.0.0"
    },
    "peerDependencies": {
        "react": ">=17"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        }
    },
    "keywords": [
        "cmyk",
        "srgb",
        "color",
        "color-conversion",
        "color-management",
        "color-space",
        "color-picker",
        "color-palette",
        "pdf",
        "preview",
        "palette",
        "dual-color",
        "print",
        "press",
        "prepress",
        "print-design",
        "pdfjs",
        "pdf-lib",
        "hex-to-cmyk",
        "rgb-to-cmyk",
        "react-color",
        "delta-e"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vjmanoj/cmyk-preview-toolkit.git"
    },
    "homepage": "https://github.com/vjmanoj/cmyk-preview-toolkit#readme",
    "bugs": {
        "url": "https://github.com/vjmanoj/cmyk-preview-toolkit/issues"
    },
    "engines": {
        "node": ">=18"
    }
}